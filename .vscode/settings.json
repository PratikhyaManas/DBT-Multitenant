{
    "chat.agentSkillsLocations": {
        ".agents/skills": true,
        ".github/skills": true,
        ".claude/skills": true,
        "~/.agents/skills": true,
        "~/.copilot/skills": true,
        "~/.claude/skills": true,
        "~/.vscode/extensions/synapsevscode.synapse-1.25.0/copilot/skills": true
    },
    "files.associations": {
        "models/**/*.sql": "jinja-sql",
        "macros/**/*.sql": "jinja-sql",
        "tests/**/*.sql": "jinja-sql",
        "**/models/**/*.sql": "jinja-sql",
        "**/macros/**/*.sql": "jinja-sql",
        "**/tests/**/*.sql": "jinja-sql"
    },
    "mssql.intelliSense.enableErrorChecking": false,
    "sql.validate.enable": false
}